---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home | My Project">
	<section class="py-20 text-center">
		<h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter mb-6 bg-linear-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
			Building the Future.
		</h1>
		<p class="text-xl text-slate-600 max-w-2xl mx-auto mb-10">
			A high-performance, type-safe project built with Astro, Tailwind v4, and pnpm.
		</p>
		<div class="flex justify-center gap-4">
			<button class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition shadow-lg shadow-blue-200">
				Get Started
			</button>
			<button class="px-8 py-3 bg-white border border-slate-200 font-semibold rounded-lg hover:border-slate-300 transition">
				Documentation
			</button>
		</div>
	</section>
</BaseLayout>