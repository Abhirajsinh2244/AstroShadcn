---
// Import global styles once in the layout
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "A professional Astro project" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-slate-50 text-slate-900 antialiased min-h-screen flex flex-col">
		<header class="p-6 border-b border-slate-200">
			<nav class="max-w-7xl mx-auto flex justify-between items-center">
				<a href="/" class="text-xl font-bold tracking-tight">BRAND</a>
				<ul class="flex gap-6 font-medium">
					<li><a href="/" class="hover:text-brand-primary transition">Home</a></li>
					<li><a href="/about" class="hover:text-brand-primary transition">About</a></li>
				</ul>
			</nav>
		</header>

		<main class="flex-grow max-w-7xl mx-auto w-full p-6">
			<slot />
		</main>

		<footer class="p-6 text-center text-slate-500 text-sm">
			&copy; {new Date().getFullYear()} Professional Astro Project.
		</footer>
	</body>
</html>